{
  "name": "ghost-engine",
  "version": "1.0.0",
  "description": "Ghost Engine — GPU-accelerated HyperFrames renderer with WebGL post-processing (bloom, motion blur, chromatic aberration, film grain)",
  "type": "module",
  "bin": {
    "ghost-engine": "./bin/ghost-engine.js"
  },
  "main": "./src/render.js",
  "exports": {
    ".": "./src/render.js",
    "./injector": "./src/injector.js",
    "./shaders": "./src/shaders/index.js"
  },
  "scripts": {
    "render": "node bin/ghost-engine.js render",
    "test": "node --test test/*.test.mjs",
    "lint": "node bin/ghost-engine.js --help"
  },
  "dependencies": {
    "hyperframes": "latest",
    "puppeteer-core": "^24.0.0",
    "sharp": "^0.33.0",
    "citty": "^0.1.6",
    "consola": "^3.2.0",
    "pathe": "^2.0.0"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "hyperframes",
    "motion-graphics",
    "webgl",
    "gpu",
    "post-processing",
    "bloom",
    "motion-blur",
    "chromatic-aberration",
    "render",
    "video",
    "after-effects"
  ],
  "author": "Rinku Sharma",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rinkusharma79346-droid/ghost-engine"
  }
}
